# Copy to room-api.env and keep it out of Git.
NETBIRD_MANAGEMENT_URL=https://legengen.top
NETBIRD_PAT=replace-with-a-server-side-netbird-pat
ROOM_API_ENCRYPTION_KEY=replace-with-a-random-secret
ROOM_API_ADMIN_TOKEN=replace-with-a-separate-disable-token
ROOM_API_ADDR=:8080
ROOM_API_DB_PATH=/var/lib/room-api/rooms.db
ROOM_API_CREATE_RATE_PER_MINUTE=5
ROOM_API_JOIN_RATE_PER_MINUTE=30
ROOM_API_PEER_RATE_PER_MINUTE=60
ROOM_API_PROVISION_CONCURRENCY=2
ROOM_API_MAX_BODY_BYTES=4096
